### 최종 결과물 코드

- AI가 생성한 전체 코드 첨부

```c

```#include <stdio.h>
#include <string.h>

#define MAX_SCHEDULES 100
#define STR_LEN 100

// 일정 정보를 담는 구조체
typedef struct {
    char title[STR_LEN];
    char date[STR_LEN];  // 예: 2024-05-20
    char time[STR_LEN];  // 예: 14:30
    char desc[STR_LEN];
} Schedule;

Schedule list[MAX_SCHEDULES];
int count = 0;

// 함수 선언
void addSchedule();
void showAll();
void updateSchedule();
void deleteSchedule();

int main() {
    int choice;

    while (1) {
        printf("\n--- [일정 관리 프로그램] ---\n");
        printf("1. 일정 추가\n2. 일정 조회\n3. 일정 수정\n4. 일정 삭제\n5. 종료\n");
        printf("선택: ");
        scanf("%d", &choice);
        getchar(); // 버퍼 비우기

        switch (choice) {
            case 1: addSchedule(); break;
            case 2: showAll(); break;
            case 3: updateSchedule(); break;
            case 4: deleteSchedule(); break;
            case 5: printf("프로그램을 종료합니다.\n"); return 0;
            default: printf("잘못된 입력입니다.\n");
        }
    }
}

// 1. 일정 추가
void addSchedule() {
    if (count >= MAX_SCHEDULES) {
        printf("저장 공간이 가득 찼습니다!\n");
        return;
    }
    printf("\n[새 일정 추가]\n");
    printf("제목: "); fgets(list[count].title, STR_LEN, stdin);
    printf("날짜(YYYY-MM-DD): "); fgets(list[count].date, STR_LEN, stdin);
    printf("시간(HH:MM): "); fgets(list[count].time, STR_LEN, stdin);
    printf("설명: "); fgets(list[count].desc, STR_LEN, stdin);

    // 개행 문자 제거
    list[count].title[strcspn(list[count].title, "\n")] = 0;
    
    count++;
    printf("일정이 성공적으로 추가되었습니다.\n");
}

// 2. 일정 조회
void showAll() {
    if (count == 0) {
        printf("\n=> 저장된 일정이 없습니다.\n");
        return;
    }
    printf("\n--- [전체 일정 목록] ---\n");
    for (int i = 0; i < count; i++) {
        printf("[%d] 제목: %s | 날짜: %s | 시간: %s", i + 1, list[i].title, list[i].date, list[i].time);
    }
}

// 3. 일정 수정
void updateSchedule() {
    showAll();
    if (count == 0) return;

    int num;
    printf("\n수정할 일정 번호를 선택하세요: ");
    scanf("%d", &num);
    getchar();

    if (num < 1 || num > count) {
        printf("유효하지 않은 번호입니다.\n");
        return;
    }

    int idx = num - 1;
    printf("새 제목: "); fgets(list[idx].title, STR_LEN, stdin);
    printf("새 날짜: "); fgets(list[idx].date, STR_LEN, stdin);
    printf("새 시간: "); fgets(list[idx].time, STR_LEN, stdin);
    printf("새 설명: "); fgets(list[idx].desc, STR_LEN, stdin);
    
    list[idx].title[strcspn(list[idx].title, "\n")] = 0;
    printf("일정이 수정되었습니다.\n");
}

// 4. 일정 삭제
void deleteSchedule() {
    showAll();
    if (count == 0) return;

    int num;
    printf("\n삭제할 일정 번호를 선택하세요: ");
    scanf("%d", &num);
    getchar();

    if (num < 1 || num > count) {
        printf("유효하지 않은 번호입니다.\n");
        return;
    }

    for (int i = num - 1; i < count - 1; i++) {
        list[i] = list[i + 1]; // 뒤의 일정을 앞으로 당김
    }
    count--;
    printf("일정이 삭제되었습니다.\n");
}
